# Instagram MCP — environment variables
# Copy to .env and fill in values. Never commit .env.

# Long-lived Instagram access token (refresh every 60 days)
META_ACCESS_TOKEN=IGAAxxxxxxxxxxxxxxxxxxxx

# Your Instagram Business account ID
IG_USER_ID=YOUR_NUMERIC_IG_USER_ID

# Transport: "stdio" for Claude Desktop, "http" for cloud deployment
MCP_TRANSPORT=stdio

# Port for HTTP mode (Railway sets this automatically)
PORT=8000
